{
  "name": "archive-of-fate-backend",
  "version": "1.0.0",
  "private": true,
  "description": "命运档案馆（Archive of Fate）- backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "postbuild": "node -e \"require('fs').copyFileSync('src/db/schema.sql','dist/db/schema.sql')\"",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:init": "tsx src/db/init.ts",
    "monitor": "tsx src/worker/chainMonitor.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "cors": "^2.8.5",
    "ethers": "^6.17.0",
    "express": "^4.19.2",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.19.0",
    "@types/pg": "^8.11.6",
    "tsx": "^4.16.0",
    "typescript": "^5.4.0"
  }
}
